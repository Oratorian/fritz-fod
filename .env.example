# Copy this file to `.env` and fill in your own values.
# Each runnable script auto-loads `.env` on startup via python-dotenv.
# Real shell environment variables override anything set here.

# ---- Required for everything ----
FRITZ_ADDRESS=192.168.178.1
FRITZ_USERNAME=username
FRITZ_PASSWORD=password

# ---- Required for the "Sync DNS" button (dashboards only) ----
# Master switch. Defaults to true if unset. Set to false (or 0/no/off) to
# disable the feature entirely — TSIG key loading is skipped at startup and
# the Sync button reports "disabled" instead of hitting BIND.
DNS_SYNC_ENABLED=false
DNS_ZONE=home.local
DNS_SERVER=192.168.178.xx
TSIG_KEY_PATH=fritzdash.key

# Optional. If unset, only forward (A) records are synced. Set to the
# in-addr.arpa zone name of a /24 reverse zone — for the 192.168.178.0/24
# subnet that's "178.168.192.in-addr.arpa" (octets reversed, no CIDR).
# Hosts outside that subnet are silently skipped.
DNS_REVERSE_ZONE=178.168.192.in-addr.arpa

# Comma-separated list of DNS labels the sync must NEVER delete, even if
# they disappear from the FRITZ!Box host list. Hand-curated records, NS
# targets, service aliases, etc. Leave empty if you don't have any.
DNS_PROTECTED_NAMES=

# Path to a YAML file mapping MAC addresses to preferred DNS labels.
# See dns_overrides.yaml.example. Leave empty to disable.
DNS_OVERRIDES_FILE=

# ---- Optional for the watchtool ----
DISCORD_WEBHOOK_URL=
LOG_FILE=fritz_watchtool.log
STATE_FILE=fritz_watchtool.state.json
